{
  "name": "palworld-server-manager",
  "version": "0.2.0",
  "private": true,
  "description": "Windows desktop app for managing a Palworld Dedicated Server",
  "author": "Null-AiLAB",
  "license": "MIT",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.0",
    "@types/pidusage": "^2.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.7"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "electron-updater": "^6.8.9",
    "pidusage": "^4.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "build": {
    "appId": "gg.palworld.servermanager",
    "productName": "Palworld Server Manager",
    "publish": [
      {
        "provider": "github",
        "owner": "Null-AiLAB",
        "repo": "PalServer",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Game",
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}
